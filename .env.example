# ═══════════════════════════════════════════════════════════════
# Goyim Agent — Environment Configuration
# Copy this file: cp .env.example .env
# Then fill in your values below
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────────────

# Solana RPC endpoint (Helius recommended — free tier available at helius.dev)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Wallet private key (base58 format — export from Phantom/Solflare)
# WARNING: Use a dedicated trading wallet, NOT your main wallet!
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# OpenRouter API key (get at openrouter.ai — top up minimum $5)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY

# ─── TELEGRAM (optional but recommended) ─────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Your Telegram chat ID (get from https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ─── LLM MODELS ──────────────────────────────────────────────

# Default model for trading decisions (Haiku = cheap & fast)
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Smart model for deep analysis (brain rewrite, post-trade debrief)
LLM_MODEL_SMART=anthropic/claude-sonnet-4

# Fast model for quick checks
LLM_MODEL_FAST=anthropic/claude-haiku-4.5

# Enable LLM post-trade analysis (costs extra LLM credits per trade)
ENABLE_POST_TRADE_ANALYSIS=false

# ─── TRADING PARAMETERS ──────────────────────────────────────

# Hunter scan interval in milliseconds (1080000 = 18 minutes)
LOOP_INTERVAL_MS=1080000

# Maximum SOL per position (caps dynamic sizing)
MAX_SOL_PER_POSITION=5

# Maximum concurrent open positions
MAX_OPEN_POSITIONS=6

# Maximum position hold time (hours) — auto-close after this
MAX_HOLD_HOURS=3

# Minimum SOL balance required to open a position
MIN_SOL_TO_OPEN=0.3

# ─── TAKE PROFIT & STOP LOSS ─────────────────────────────────

# Take profit at this PnL percentage
TAKE_PROFIT_PERCENT=8

# Stop loss at this PnL percentage (negative number)
STOP_LOSS_PCT=-6
STOP_LOSS_PERCENT=-6

# Trailing TP: activates when PnL reaches this % (0 = disabled)
TRAILING_TP_ACTIVATION=6

# Trailing TP: trail distance from peak PnL (%)
TRAILING_TP_TRAIL=3

# Fee take profit: close if claimable fees >= this fraction of deployed SOL
# 0.15 = close when fees reach 15% of deployed SOL
TAKE_PROFIT_FEE_PCT=0.15

# Minimum fee APR to keep holding (%, close if pool dries up)
MIN_FEE_APR_TO_HOLD=10

# Out-of-range grace period (minutes) before auto-close
OOR_WAIT_MINUTES=30

# ─── POOL FILTERS ────────────────────────────────────────────

# Minimum 24h volume ($) to consider a pool
MIN_POOL_VOLUME_USD=100000

# Minimum fee APR (%) to consider a pool
MIN_POOL_FEE_APR=1.0

# Minimum organic score (0-100) — rejects wash-traded/bot pools
MIN_ORGANIC_SCORE=35

# Maximum TVL ($) — reject oversaturated pools with too many LPs
MAX_POOL_TVL_USD=600000

# ─── TOKEN FILTERS ───────────────────────────────────────────

# Minimum token age (hours) — skip brand-new tokens (rug risk)
MIN_TOKEN_AGE_HOURS=1

# Maximum token age (days) — skip old/dead tokens
MAX_TOKEN_AGE_DAYS=30

# Volume 24h range ($) for token on DexScreener
MIN_VOLUME_24H=100000
MAX_VOLUME_24H=15000000

# Liquidity range ($) for token
MIN_LIQUIDITY_USD=15000
MAX_LIQUIDITY_USD=1000000

# ─── TOKEN MANAGEMENT ────────────────────────────────────────

# Auto-swap leftover tokens to SOL after closing positions
AUTO_SWAP_ENABLED=true

# Minimum USD value to trigger auto-swap
AUTO_SWAP_MIN_USD=1

# Cooldown per token after close (hours) — avoid re-entering too fast
TOKEN_COOLDOWN_HOURS=1

# Skip stable/large-cap pairs (SOL-USDC, etc)
SKIP_STABLE_PAIRS=true

# Permanently blacklisted tokens (comma-separated, uppercase symbols)
BLACKLISTED_TOKENS=JUP,BONK,WIF,POPCAT,PYTH,RAY,ORCA,MNGO,JLP,WBTC,WETH,CBBTC
